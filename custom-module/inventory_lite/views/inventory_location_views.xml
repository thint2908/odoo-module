<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_inventory_location_list" model="ir.ui.view">
        <field name="name">inventory.location.list</field>
        <field name="model">inventory.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="usage"/>
            </list>
        </field>
        
    </record>

    <record id="view_inventory_location_form" model="ir.ui.view">
        <field name="name">inventory.location.form</field>
        <field name="model">inventory.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="usage"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_inventory_location" model="ir.actions.act_window">
        <field name="name">Location</field>
        <field name="res_model">inventory.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_inventory_location"
            name="Locations"
            parent="menu_inventory_lite_root"
            action="action_inventory_location"
            sequence="10"/>
</odoo>
