<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- List View -->
    <record id="view_inventory_move_list" model="ir.ui.view">
        <field name="name">inventory.move.list</field>
        <field name="model">inventory.move</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
                <field name="source_location_id"/>
                <field name="dest_location_id"/>
                <field name="quantity"/>
                <field name="state"
                        decoration-success="state == 'done'"
                        decoration-warning="state == 'draft'"
                        widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_inventory_move_form" model="ir.ui.view">
        <field name="name">inventory.move.form</field>
        <field name="model">inventory.move</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button
                        name="action_done"
                        type="object"
                        string="Done"
                        invisible="state == 'done'"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                    />

                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_id"/>
                        <field name="source_location_id"/>
                        <field name="dest_location_id"/>
                        <field name="quantity"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_inventory_move" model="ir.actions.act_window">
        <field name="name">Moves</field>
        <field name="res_model">inventory.move</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_inventory_move"
        name="Moves"
        parent="menu_inventory_lite_root"
        action="action_inventory_move"
        sequence="30"
    />

</odoo>