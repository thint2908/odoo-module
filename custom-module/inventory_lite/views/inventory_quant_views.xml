<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_inventory_quant_list" model="ir.ui.view">
        <field name="name">inventory.quant.list</field>
        <field name="model">inventory.quant</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_id"/>
                <field name="location_id"/>
                <field name="quantity"/>
            </list>
        </field>
        
    </record>

    <record id="view_inventory_quant_form" model="ir.ui.view">
        <field name="name">inventory.quant.form</field>
        <field name="model">inventory.quant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="location_id"/>
                        <field name="quantity"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_inventory_quant" model="ir.actions.act_window">
        <field name="name">Quantity</field>
        <field name="res_model">inventory.quant</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_inventory_quant"
            name="Quants"
            parent="menu_inventory_lite_root"
            action="action_inventory_quant"
            sequence="10"/>
</odoo>
