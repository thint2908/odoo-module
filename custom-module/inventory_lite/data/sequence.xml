<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- MOVE SEQUENCE -->
    <record id="seq_inventory_move" model="ir.sequence">
        <field name="name">Inventory Move</field>
        <field name="code">inventory.move</field>
        <field name="prefix">MOVE</field>
