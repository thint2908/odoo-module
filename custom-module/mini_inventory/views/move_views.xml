<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== FORM VIEW ===================== -->
    <record id="view_mini_move_form" model="ir.ui.view">
        <field name="name">mini_inventory.move.form</field>
        <field name="model">mini_inventory.move</field>
        <field name="arch" type="xml">
            <form string="Stock Move">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="qty"/>
                            <field name="uom" readonly="1"/>
                        </group>
                        <group>
                            <field name="location_src_id"/>
                            <field name="location_dest_id"/>
                            <field name="state" readonly="1"/>
                            <field name="date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================== LIST VIEW ===================== -->
    <record id="view_mini_move_list" model="ir.ui.view">
        <field name="name">mini_inventory.move.list</field>
        <field name="model">mini_inventory.move</field>
        <field name="arch" type="xml">
            <list string="Stock Moves" decoration-muted="state == 'cancelled'">
                <field name="date"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="uom"/>
                <field name="location_src_id"/>
                <field name="location_dest_id"/>
                <field name="state"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- ===================== SEARCH VIEW ===================== -->
    <record id="view_mini_move_search" model="ir.ui.view">
        <field name="name">mini_inventory.move.search</field>
        <field name="model">mini_inventory.move</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="product_id"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
            </search>
        </field>
    </record>

    <!-- ===================== ACTION ===================== -->
    <record id="action_mini_move" model="ir.actions.act_window">
        <field name="name">Stock Moves</field>
        <field name="res_model">mini_inventory.move</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mini_move_search"/>
    </record>

</odoo>