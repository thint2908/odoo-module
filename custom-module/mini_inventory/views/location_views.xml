<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== FORM VIEW ===================== -->
    <record id="view_mini_location_form" model="ir.ui.view">
        <field name="name">mini_inventory.location.form</field>
        <field name="model">mini_inventory.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="location_type"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================== LIST VIEW ===================== -->
    <record id="view_mini_location_list" model="ir.ui.view">
        <field name="name">mini_inventory.location.list</field>
        <field name="model">mini_inventory.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="code"/>
                <field name="name"/>
                <field name="location_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ===================== SEARCH VIEW ===================== -->
    <record id="view_mini_location_search" model="ir.ui.view">
        <field name="name">mini_inventory.location.search</field>
        <field name="model">mini_inventory.location</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Internal" name="internal"
                        domain="[('location_type','=','internal')]"/>
                <filter string="Archived" name="inactive"
                        domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type"
                            context="{'group_by': 'location_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ===================== ACTION ===================== -->
    <record id="action_mini_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">mini_inventory.location</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mini_location_search"/>
        <!-- Only show active locations by default -->
        <field name="domain">[('active', '=', True)]</field>
    </record>

</odoo>