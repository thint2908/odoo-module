<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== FORM VIEW ===================== -->
    <record id="view_mini_product_form" model="ir.ui.view">
        <field name="name">mini_inventory.product.form</field>
        <field name="model">mini_inventory.product</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Product Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General Info">
                            <field name="code"/>
                            <field name="uom"/>
                            <field name="cost_price"/>
                        </group>
                        <group string="Stock">
                            <!-- readonly: qty_on_hand is computed, user cannot edit -->
                            <field name="qty_on_hand" readonly="1"/>
                        </group>
                    </group>

                    <!-- Notebook = tabbed section at the bottom of the form -->
                    <notebook>
                        <page string="Stock by Location">
                            <field name="location_qty_ids" readonly="1">
                                <list>
                                    <field name="location_id"/>
                                    <field name="qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ===================== LIST VIEW ===================== -->
    <record id="view_mini_product_list" model="ir.ui.view">
        <field name="name">mini_inventory.product.list</field>
        <field name="model">mini_inventory.product</field>
        <field name="arch" type="xml">
            <list string="Products">
                <field name="code"/>
                <field name="name"/>
                <field name="uom"/>
                <field name="cost_price"/>
                <!-- decoration-warning: highlights row in orange when qty is 0 -->
                <field name="qty_on_hand"
                       decoration-warning="qty_on_hand == 0"
                       decoration-danger="qty_on_hand &lt; 0"/>
            </list>
        </field>
    </record>

    <!-- ===================== SEARCH VIEW ===================== -->
    <record id="view_mini_product_search" model="ir.ui.view">
        <field name="name">mini_inventory.product.search</field>
        <field name="model">mini_inventory.product</field>
        <field name="arch" type="xml">
            <search string="Search Products">
                <field name="name" string="Product"/>
                <field name="code" string="SKU"/>
                <!-- Filter: show only products with stock -->
                <filter string="In Stock" name="in_stock"
                        domain="[('qty_on_hand', '&gt;', 0)]"/>
                <!-- Filter: show products with zero stock -->
                <filter string="Out of Stock" name="out_of_stock"
                        domain="[('qty_on_hand', '=', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Unit of Measure" name="group_uom"
                            context="{'group_by': 'uom'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ===================== ACTION ===================== -->
    <record id="action_mini_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">mini_inventory.product</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_mini_product_search"/>
    </record>

</odoo>