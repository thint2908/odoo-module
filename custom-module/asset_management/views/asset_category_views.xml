<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asset Category Form View -->
    <record id="view_asset_category_form" model="ir.ui.view">
        <field name="name">asset.category.form</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <form string="Asset Category">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Hardware"/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" invisible="1"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Assets in Category">
                            <field name="asset_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="serial_number"/>
                                    <field name="assignee_id"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Asset Category Tree View -->
    <record id="view_asset_category_tree" model="ir.ui.view">
        <field name="name">asset.category.list</field>
        <field name="model">asset.category</field>
        <field name="arch" type="xml">
            <list string="Asset Categories">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Asset Category Action -->
    <record id="action_asset_category" model="ir.actions.act_window">
        <field name="name">Asset Categories</field>
        <field name="res_model">asset.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new asset category!
            </p>
            <p>
                Categories help you organize your assets (e.g. Software, Hardware, Furniture).
            </p>
        </field>
    </record>
</odoo>
