<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Asset Form View -->
    <record id="view_asset_management_form" model="ir.ui.view">
        <field name="name">asset.management.form</field>
        <field name="model">asset.management</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,maintenance,retired"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. ThinkPad T14"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="serial_number"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="assignee_id"/>
                            <field name="purchase_date"/>
                            <field name="cost" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional information..."/>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter for tracking -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Asset List View -->
    <record id="view_asset_management_list" model="ir.ui.view">
        <field name="name">asset.management.list</field>
        <field name="model">asset.management</field>
        <field name="arch" type="xml">
            <list string="Assets" decoration-info="state == 'draft'" decoration-success="state == 'assigned'" decoration-warning="state == 'maintenance'" decoration-muted="state == 'retired'">
                <field name="name"/>
                <field name="category_id"/>
                <field name="serial_number"/>
                <field name="assignee_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'assigned'" decoration-warning="state == 'maintenance'" decoration-muted="state == 'retired'"/>
            </list>
        </field>
    </record>

    <!-- Asset Search View -->
    <record id="view_asset_management_search" model="ir.ui.view">
        <field name="name">asset.management.search</field>
        <field name="model">asset.management</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="name"/>
                <field name="serial_number"/>
                <field name="assignee_id"/>
                <field name="category_id"/>
                <separator/>
                <filter string="Available" name="available" domain="[('state', '=', 'draft')]"/>
                <filter string="Assigned" name="assigned" domain="[('state', '=', 'assigned')]"/>
                <filter string="My Assigned Assets" name="my_assets" domain="[('assignee_id', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Assignee" name="group_by_assignee" context="{'group_by': 'assignee_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Asset Action -->
    <record id="action_asset_management" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">asset.management</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_asset_management_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first asset!
            </p>
            <p>
                Manage company assets like laptops, monitors, etc. and assign them to employees.
            </p>
        </field>
    </record>
</odoo>
