<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <!-- List view -->
    <record id="view_todo_task_list" model="ir.ui.view">
        <field name="name">todo.task.list</field> <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="name" decoration-success="is_done == True" decoration-bf="is_done == True" decoration-danger="is_overdue == True" />
                <field name="created_at" />
                <field name="due_date" widget="remaining_days"/>
                <field name="remaining_time"/>
                <field name="is_done" widget="boolean_toggle"/>
                <field name="is_overdue" column_invisible="True"/>
                <field name="description" placeholder="Add details about this task..."/>
            </list>
        </field>
    </record>

    <record id="view_todo_task_kanban" model="ir.ui.view">
        <field name="name">todo.task.kanban</field>
        <field name="model">todo.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="is_done" class="o_kanban_small_column" records_draggable="true">
                <field name="name"/>
                <field name="is_done"/>
                <field name="is_overdue"/>
                <field name="due_date"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click d-flex flex-column">
                            <div class="fw-bold fs-5 mb-2">
                                <field name="name"/>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div class="text-muted small">
                                    <i class="fa fa-calendar me-1"/>
                                    <field name="due_date"/>
                                </div>
                                
                                <div>
                                    <span t-if="record.is_overdue.raw_value" class="badge rounded-pill text-bg-danger">Overdue</span>
                                    <span t-if="record.is_done.raw_value" class="badge rounded-pill text-bg-success">Done</span>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-name="card">
                        <div class="oe_kanban_global_click d-flex flex-column">
                            <div class="fw-bold fs-5 mb-2">
                                <field name="name"/>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <div class="text-muted small">
                                    <i class="fa fa-calendar me-1"/>
                                    <field name="due_date"/>
                                </div>
                                
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_todo_task" model="ir.actions.act_window">
        <field name="name">Todo Tasks</field>
        <field name="res_model">todo.task</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
    <menuitem id="menu_todo_root" 
            name="Todo App" 
            web_icon="base,static/description/icon.png" 
            sequence="10"/>

    <menuitem id="menu_todo_task" 
            name="My Tasks" 
            parent="menu_todo_root" 
            action="action_todo_task" 
            sequence="10"/>

</data>
</odoo>