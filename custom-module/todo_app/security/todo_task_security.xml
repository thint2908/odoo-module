        <record id="rule_todo_task_user"
                model="ir.rule">
            <field name="name">User: Own Tasks Only</field>
            <field name="model_id"
                   ref="model_todo_task" />
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_user'))]" />
        </record>

        <record id="rule_todo_task_admin"
                model="ir.rule">
            <field name="name">Admin: All Tasks</field>
            <field name="model_id"
                   ref="model_todo_task" />
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('base.group_system')), (4, ref('base.group_erp_manager'))]" />
        </record>
    </data>
